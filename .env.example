# ─── Vyke IDE — Configuration ────────────────────────────────────────────────
# Copy this file to .env and adjust the values to your setup.
# Native install : ./setup.sh will generate .env automatically.
# Docker install : edit this file, rename to .env, then docker compose up.

# Port the server listens on
VYKE_PORT=4242

# Ollama API URL
# Native  → http://localhost:11434
# Docker  → http://host.docker.internal:11434  (default in compose)
VYKE_OLLAMA_URL=http://localhost:11434

# Chat model  — used for questions, explanations, generation
VYKE_CHAT_MODEL=mistral-small3.2:24b

# Code model  — used for inline completion suggestions
VYKE_CODE_MODEL=qwen2.5-coder:7b

# ── Docker only ───────────────────────────────────────────────────────────────
# Absolute path on your HOST machine to expose as the workspace inside Vyke.
# Maps to /workspace inside the container.
WORKSPACE_PATH=/home/youruser
